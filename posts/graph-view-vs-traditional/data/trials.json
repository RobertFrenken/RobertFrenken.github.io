{
  "experiment_metadata": {
    "title": "Graph-View vs Traditional Code Exploration for LLM Agents",
    "hypothesis": "Graph-based navigation reduces token usage and improves architectural finding quality compared to traditional grep/glob exploration, while traditional exploration better surfaces line-level code issues.",
    "independent_variable": "exploration_method",
    "dependent_variables": [
      "wall_clock_seconds",
      "total_tokens",
      "tool_calls",
      "findings_count",
      "findings_by_priority",
      "unique_findings",
      "overlapping_findings",
      "bugs_found",
      "lines_removable",
      "tokens_per_finding",
      "architectural_findings",
      "code_level_findings"
    ],
    "controlled_variables": {
      "model": "claude-opus-4-6",
      "agent_type": "general-purpose",
      "run_in_background": true,
      "codebase_context": "Same commit, same session, same prompt structure"
    },
    "limitations": [
      "Single codebase (KD-GAT) — generalizability unknown",
      "Agents are not identical prompts — method instructions differ by design",
      "No repeated trials yet — variance unknown",
      "Token counts include tool results, not just generation",
      "Wall-clock time includes queuing and tool execution latency",
      "Findings quality is subjectively categorized by the researcher",
      "Graph infrastructure has upfront build cost not captured in trial timing"
